#include <stdio.h>
#include "main.h"
/**
 *_isaplha -  checks for an alphabetic character
 *@c: charecter to be checked
 *
 *Return: Returns 1 if c is a letter, lowercase or uppercase Returns 0 otherwise
 */

int _isalpha(int c);
int _isalpha(int c)
{
if ((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z'))
{
return (1);
}
else
{
return (0);
}
}
